# ── Server ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (MongoDB Atlas) ─────────────────────────────────────
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/auragems

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_very_long_random_string_min_32_chars

# ── Cloudinary (Free image storage — get from cloudinary.com) ───
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Payments (Razorpay) ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS (only if frontend is on a different domain) ────────────
# ALLOWED_ORIGINS=https://auragems.up.railway.app
